{
  "name": "polygraph",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0 OR MIT",
  "bin": {
    "polygraph": "cli/index.ts"
  },
  "type": "module",
  "scripts": {
    "polygraph": "bun run cli/index.ts",
    "check": "bun run cli/index.ts check .",
    "diff": "bun run cli/index.ts diff .",
    "dev": "bun scripts/dev.mjs",
    "dev:next": "next dev -p 3003",
    "dev:sidecar": "bun run sidecar/server.ts",
    "build": "next build",
    "build:sidecar": "bun build --compile sidecar/server.ts --outfile dist/polygraph-sidecar",
    "tauri": "tauri",
    "tauri:sidecar": "bun scripts/build-sidecar.mjs",
    "start": "bunx serve out",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt --ignore-path .gitignore --ignore-path .oxfmtignore .",
    "format:check": "oxfmt --ignore-path .gitignore --ignore-path .oxfmtignore --check .",
    "test": "bun test"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.27.0",
    "@dagrejs/dagre": "^1.1.4",
    "@emotion/react": "^11.14.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "d3-force": "^3.0.0",
    "next": "^15.5.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "^1.24.0",
    "ts-morph": "^25.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.5",
    "@napi-rs/cli": "^2",
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.1.0",
    "@types/bun": "^1.1.14",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "happy-dom": "^20.10.5",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^5.7.0"
  }
}
