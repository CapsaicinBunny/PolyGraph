{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PolyGraph",
  "version": "0.1.0",
  "identifier": "com.polygraph.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3003",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "PolyGraph",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/polygraph-sidecar"],
    "resources": {
      "../analyzer-core/analyzer-core.node": "analyzer-core.node",
      "../language-packs": "language-packs"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
